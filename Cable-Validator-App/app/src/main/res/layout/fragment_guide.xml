<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panduan Standar"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/brand_blue"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panduan standar ukuran fisik, batas hambatan kabel, dan metode kalkulasi kelayakan yang digunakan oleh sistem."
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/blue_icon_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/brand_blue"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALGORITMA VALIDASI KABEL"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/brand_blue" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aplikasi menentukan kelayakan kabel dengan cara menghitung Batas Resistansi Maksimal (R_max) berdasarkan konfigurasi standar, lalu membandingkannya dengan hasil ukur aktual dari perangkat keras."
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#10000000"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R_max = R_ideal × L × (1 + T/100)"
                        android:fontFamily="monospace"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keterangan Variabel:\n• R_max = Batas hambatan tertinggi (Ω)\n• R_ideal = Hambatan acuan standar (Ω/m)\n• L = Panjang kabel yang diukur (Meter)\n• T = Persentase toleransi kelonggaran (%)"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#20000000"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOGIKA VALIDASI:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LULUS : Jika R_aktual ≤ R_max\n(Hambatan rendah, kualitas tembaga baik)\n\nGAGAL : Jika R_aktual > R_max\n(Hambatan tinggi, indikasi kabel campuran)"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Tabel Standar Indonesia (SNI)"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berikut tabel standar kabel SNI (SNI IEC 60228:2009). Tabel ini digunakan sebagai penentu hambatan ideal (R_ideal). Nilai hambatan dikonversi dari satuan per kilometer menjadi per meter."
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
