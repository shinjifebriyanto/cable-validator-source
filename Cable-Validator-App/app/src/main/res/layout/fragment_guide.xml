                </TableRow>

                <TableRow android:layout_marginBottom="10dp">
                    <TextView android:text="0.5 mm²" android:textSize="13sp" android:textColor="?attr/colorOnSurface" />
                    <TextView android:text="39.0 Ω/km" android:textSize="12sp" android:gravity="center" android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView android:text="0.0390 Ω/m" android:textSize="13sp" android:gravity="end" android:textColor="?attr/colorOnSurface" />
