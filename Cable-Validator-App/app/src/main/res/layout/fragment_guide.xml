                    <TextView android:text="24" android:textSize="13sp" android:textColor="?attr/colorOnSurface" />
                    <TextView android:text="0.2 mm²" android:textSize="12sp" android:gravity="center" android:textColor="?attr/colorOnSurfaceVariant" />
